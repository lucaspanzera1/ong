# Global env file for the monorepo (root). Copy to .env and fill in values.
# Shared by apps/web (via vite envDir), apps/api (via ConfigModule) and docker-compose.

# --- api ---
PORT=3000

# --- mongo (docker-compose + api) ---
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASSWORD=example
MONGO_DB=ong
MONGODB_URI=mongodb://root:example@localhost:27017/ong?authSource=admin

# --- web ---
VITE_API_URL=/api                    # caminho relativo — o front-end faz proxy de /s pra api (mesma origem)
VITE_ADMIN_PATH=                   # deve ser igual a AUTH_REDIRECT_PATH abaixo (rota admin não-óbvia)

# --- auth ---
AUTH_ALLOWED_EMAIL=                # único email autorizado a logar
AUTH_JWE_SECRET=                   # 32 bytes em base64 (gerar com: openssl rand -base64 32)
AUTH_MAGIC_LINK_TTL_SECONDS=600    # 10 min de validade do link recebido por email
AUTH_SESSION_TTL_SECONDS=1800      # 30 min de sessão (cookie)
AUTH_COOKIE_NAME=ong_session
AUTH_REDIRECT_PATH=                # path não-óbvio no front-end pra onde redireciona após validar o link
APP_URL=http://localhost:5173      # origem do front-end (CORS + link de redirect)
API_PUBLIC_URL=http://localhost:5173/s  # base pública da api vista pelo browser (via proxy /s do front-end), usada no link do email

# --- smtp ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ONG <no-reply@example.com>"
