{
  "name": "ong",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "predev": "docker compose up -d",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:prod": "pnpm --filter web build:prod && pnpm --filter api build",
    "start:prod": "pnpm build:prod && NODE_ENV=production turbo run start:prod",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f mongo"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
